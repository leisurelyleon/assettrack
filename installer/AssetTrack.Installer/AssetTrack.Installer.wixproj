<Project Sdk="WixToolset.Sdk/4.0.5">

  <PropertyGroup>
    <OutputName>AssetTrack</OutputName>
    <OutputType>Package</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <!-- The published app payload is staged here by the release workflow. -->
    <BindPath Include="$(PublishDir)" />
  </ItemGroup>

</Project>
